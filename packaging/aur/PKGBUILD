# Maintainer: Markus Leitermann <admin@ailinux.me>
pkgname=aicoder
pkgver=0.3.1
pkgrel=1
pkgdesc="Terminal Coding & DevOps Agent for AILinux/TriForce — autonomous tool loop, opencode-style UI"
arch=('x86_64')
url="https://github.com/derleiti/ai-coder"
license=('MIT')
depends=('glibc')
optdepends=('git: git_ops support')
source=("aicoder-${pkgver}::https://github.com/derleiti/ai-coder/releases/download/v${pkgver}/aicoder-${pkgver}-x86_64-linux")
sha256sums=('bdaccdaa78fbea8a37fac8efd9057a7993dcb668f8cfbb25a2f3c2c885e5a00e')

package() {
    install -Dm755 "$srcdir/aicoder-${pkgver}" "$pkgdir/usr/bin/aicoder"
    install -Dm644 /dev/stdin "$pkgdir/usr/share/licenses/$pkgname/LICENSE" << 'EOF'
MIT License — Copyright (c) 2026 Markus Leitermann
EOF
    install -d "$pkgdir/usr/share/doc/$pkgname"
    echo "ai-coder v0.3.1 — https://ailinux.me" > "$pkgdir/usr/share/doc/$pkgname/README"
}
